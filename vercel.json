{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "epicroofingtx.com" }],
      "destination": "https://www.epicroofingtx.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/index.html", "destination": "/" },
    { "source": "/calculator", "destination": "/calculator.html" },
    { "source": "/roof-leak-detection-houston", "destination": "/roof-leak-detection-houston.html" },
    { "source": "/affordable-roofing-houston", "destination": "/affordable-roofing-houston.html" },
    { "source": "/blog/roof-leak-detection-houston-guide", "destination": "/blog/roof-leak-detection-houston-guide.html" },
    { "source": "/blog/best-affordable-roofing-contractors-houston", "destination": "/blog/best-affordable-roofing-contractors-houston.html" }
  ]
}
